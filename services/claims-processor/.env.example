# ============================================================================
# Claims Processor Service - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# Kafka Configuration (Confluent Cloud)
# ----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=pkc-4rn2p.canadacentral.azure.confluent.cloud:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=your-kafka-api-key
KAFKA_SASL_PASSWORD=your-kafka-api-secret
KAFKA_GROUP_ID=claims-processor-group
KAFKA_AUTO_OFFSET_RESET=earliest

# ----------------------------------------------------------------------------
# Kafka Topics
# ----------------------------------------------------------------------------
KAFKA_TOPIC_INGEST=claims.ingest
KAFKA_TOPIC_PROCESSED=claims.processed
KAFKA_TOPIC_APPROVED=claims.approved
KAFKA_TOPIC_ESCALATED=claims.escalated
KAFKA_TOPIC_DLQ=claims.dlq

# ----------------------------------------------------------------------------
# CockroachDB Configuration (Serverless)
# ----------------------------------------------------------------------------
DB_HOST=your-cluster.aws-us-east-1.cockroachlabs.cloud
DB_PORT=26257
DB_NAME=insurance_claims
DB_USER=your-username
DB_PASSWORD=your-password
DB_SSLMODE=require

# Chainlit Configuration
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

# Embeddings Configuration (Vector Database)
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.7

# IBM Watsonx.ai Configuration
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://ca-tor.ml.cloud.ibm.com
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct


# ----------------------------------------------------------------------------
# AI Logic Gate Thresholds
# ----------------------------------------------------------------------------
# Auto-approve claims below this amount (in dollars) if risk is low
AUTO_APPROVE_AMOUNT_THRESHOLD=2000.0

# Auto-approve claims with risk score below this threshold
AUTO_APPROVE_RISK_THRESHOLD=20

# Escalate claims with risk score above this threshold
ESCALATION_RISK_THRESHOLD=80

# ============================================================================
# Configuration Notes:
# ============================================================================
# 
# Kafka Setup:
# - Get credentials from Confluent Cloud console
# - Ensure all topics are created before starting the service
# - Topics: claims.ingest, claims.processed, claims.approved, 
#           claims.escalated, claims.dlq
#
# CockroachDB Setup:
# - Use CockroachDB Serverless (free tier available)
# - Connection string format: 
#   postgresql://user:password@host:26257/dbname?sslmode=require
# - Run database migrations before starting service
#
# AI Logic Gate:
# - Claims are auto-approved if:
#   * claim_amount < AUTO_APPROVE_AMOUNT_THRESHOLD AND
#   * risk_score < AUTO_APPROVE_RISK_THRESHOLD
# - Claims are escalated if:
#   * risk_score > ESCALATION_RISK_THRESHOLD
# - All other claims go to manual review (UNDER_REVIEW status)
#
# ============================================================================